@model IEnumerable<ProductManagement.Models.Product>

@{
    ViewData["Title"] = "Product Management";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-0 fw-bold text-dark">
                <i class="bi bi-box-seam me-2 text-primary"></i>Product Management
            </h1>
            <p class="text-muted mt-1">Manage your product inventory</p>
        </div>
        <a asp-action="Create" class="btn btn-primary px-4">
            <i class="bi bi-plus-lg me-1"></i> New Product
        </a>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search & Filter -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Search</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentSearch"]"
                               class="form-control" placeholder="Search by name, description, category...">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All Categories</option>
                        @foreach (var cat in (List<string>)ViewData["Categories"]!)
                        {
                            <option value="@cat" selected="@(ViewData["CurrentCategory"]?.ToString() == cat)">@cat</option>
                        }
                    </select>
                </div>
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-funnel me-1"></i> Filter
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                        <i class="bi bi-x-circle me-1"></i> Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 bg-primary bg-opacity-10 text-center py-3">
                <div class="h3 fw-bold text-primary mb-0">@Model.Count()</div>
                <div class="text-muted small">Total Products</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-success bg-opacity-10 text-center py-3">
                <div class="h3 fw-bold text-success mb-0">@Model.Count(p => p.IsActive)</div>
                <div class="text-muted small">Active</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-warning bg-opacity-10 text-center py-3">
                <div class="h3 fw-bold text-warning mb-0">@Model.Count(p => p.Stock < 10)</div>
                <div class="text-muted small">Low Stock (&lt;10)</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-info bg-opacity-10 text-center py-3">
                <div class="h3 fw-bold text-info mb-0">@Model.Select(p => p.Category).Distinct().Count()</div>
                <div class="text-muted small">Categories</div>
            </div>
        </div>
    </div>

    <!-- Products Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-4 text-muted"></i>
                    <p class="text-muted mt-3">No products found. <a asp-action="Create">Add one now.</a></p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>
                                    <a asp-action="Index"
                                       asp-route-sortOrder="@ViewData["NameSortParam"]"
                                       asp-route-searchString="@ViewData["CurrentSearch"]"
                                       asp-route-category="@ViewData["CurrentCategory"]"
                                       class="text-decoration-none text-dark fw-semibold">
                                        Name <i class="bi bi-arrow-down-up ms-1 small"></i>
                                    </a>
                                </th>
                                <th>Category</th>
                                <th>
                                    <a asp-action="Index"
                                       asp-route-sortOrder="@ViewData["PriceSortParam"]"
                                       asp-route-searchString="@ViewData["CurrentSearch"]"
                                       asp-route-category="@ViewData["CurrentCategory"]"
                                       class="text-decoration-none text-dark fw-semibold">
                                        Price <i class="bi bi-arrow-down-up ms-1 small"></i>
                                    </a>
                                </th>
                                <th>
                                    <a asp-action="Index"
                                       asp-route-sortOrder="@ViewData["StockSortParam"]"
                                       asp-route-searchString="@ViewData["CurrentSearch"]"
                                       asp-route-category="@ViewData["CurrentCategory"]"
                                       class="text-decoration-none text-dark fw-semibold">
                                        Stock <i class="bi bi-arrow-down-up ms-1 small"></i>
                                    </a>
                                </th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model)
                            {
                                <tr>
                                    <td class="text-muted small">@product.Id</td>
                                    <td>
                                        <span class="fw-semibold">@product.Name</span>
                                        @if (!string.IsNullOrEmpty(product.Description))
                                        {
                                            <br /><small class="text-muted">@(product.Description.Length > 50 ? product.Description[..50] + "..." : product.Description)</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary rounded-pill">@product.Category</span>
                                    </td>
                                    <td class="fw-semibold text-success">@product.Price.ToString("C")</td>
                                    <td>
                                        @if (product.Stock == 0)
                                        {
                                            <span class="badge bg-danger">Out of Stock</span>
                                        }
                                        else if (product.Stock < 10)
                                        {
                                            <span class="badge bg-warning text-dark">@product.Stock (Low)</span>
                                        }
                                        else
                                        {
                                            <span class="text-dark">@product.Stock</span>
                                        }
                                    </td>
                                    <td>
                                        @if (product.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@product.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@product.Id"
                                               class="btn btn-outline-info" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@product.Id"
                                               class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@product.Id"
                                               class="btn btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
